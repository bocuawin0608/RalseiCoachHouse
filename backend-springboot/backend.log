        cargo_ticket_detail ctd 
            ON ctd.cargoTicketId = cargo.cargoTicketId     
    WHERE
        cargo.tripId = t.tripId       
        AND cargo.[status] NOT IN ('CANCELLED', 'REJECTED', 'ABANDONED') ) cargo_load 
