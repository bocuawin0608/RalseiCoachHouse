    CAST(t.departureTime AS DATE) = ?   
    AND (
        ? IS NULL 
        OR t.routeId = ?
    )   
    AND (
        ? IS NULL 
        OR t.[status] = ?
    )   
    AND (
        ? IS NULL        
        OR (
            ? = 'MORNING' 
            AND CAST(t.departureTime AS TIME) < '12:00:00'
        )        
        OR (
            ? = 'EVENING' 
            AND CAST(t.departureTime AS TIME) >= '12:00:00'
        )
    ) 
ORDER BY
    CASE 
        WHEN c.[status] = 'HAVE_INCIDENT' 
            THEN 0 
        ELSE 1 
END,
